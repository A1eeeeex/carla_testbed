# 复制为 .env，并按本机填写路径（.env 不进 Git）

# CARLA
CARLA_ROOT=/path/to/CARLA_0.9.16

# Apollo（仅 Apollo 模式需要）
APOLLO_ROOT=/path/to/apollo
APOLLO_DOCKER_CONTAINER=apollo_dev_x86_64

# ROS2
ROS_DOMAIN_ID=0

# 可选：显式指定附加本地配置文件（逗号分隔）
# CARLA_TESTBED_LOCAL_CONFIGS=configs/local.pc_a.yaml,configs/local.private.yaml
